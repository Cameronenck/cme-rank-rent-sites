<svg width="200" height="200" xmlns="http://www.w3.org/2000/svg">
  <!-- Badge background -->
  <circle cx="100" cy="100" r="95" fill="#1A1F36" stroke="#C8102E" stroke-width="5"/>
  
  <!-- Cowboy/Rider silhouette -->
  <g transform="translate(100,100)">
    <!-- Horse body -->
    <ellipse cx="-5" cy="15" rx="35" ry="20" fill="#C8102E"/>
    <!-- Horse head/neck -->
    <ellipse cx="-25" cy="-5" rx="15" ry="25" fill="#C8102E"/>
    <!-- Rider body -->
    <rect x="-15" y="-10" width="20" height="25" fill="#C8102E"/>
    <!-- Rider hat -->
    <ellipse cx="-5" cy="-25" rx="12" ry="8" fill="#C8102E"/>
    <!-- Hat brim -->
    <ellipse cx="-5" cy="-22" rx="18" ry="4" fill="#C8102E"/>
    
    <!-- Horse legs (simplified) -->
    <rect x="-30" y="30" width="6" height="15" fill="#C8102E"/>
    <rect x="-15" y="30" width="6" height="15" fill="#C8102E"/>
    <rect x="5" y="30" width="6" height="15" fill="#C8102E"/>
    <rect x="20" y="30" width="6" height="15" fill="#C8102E"/>
  </g>
  
  <!-- Text around the badge -->
  <path id="circle" d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0" fill="none"/>
  <text font-family="serif" font-size="14" font-weight="bold" fill="white" text-anchor="middle">
    <textPath href="#circle" startOffset="25%">AMERICAN LAND TRUST</textPath>
  </text>
  
  <!-- Bottom text -->
  <text x="100" y="180" font-family="serif" font-size="12" font-weight="bold" fill="white" text-anchor="middle">EST. 2024</text>
</svg>